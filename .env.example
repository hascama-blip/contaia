# ============================================================
#  ContaIA — Configuración de entorno
# ============================================================
# Copia este archivo a `.env.local` y completa los valores.
# Si NO configuras las credenciales SUNAT, la app funciona en
# MODO SIMULADO (datos de ejemplo) para que puedas probar todo.
# ============================================================

# --- Selección de fuente de datos -----------------------------
# auto    -> elige sola: apis.net.pe si hay token, luego SOL, luego simulado
# apisnet -> fuerza apis.net.pe
# oficial -> fuerza API oficial SUNAT (SOL)
# mock    -> fuerza modo simulado
SUNAT_PROVIDER=auto

# --- Fuente externa: apis.net.pe (RECOMENDADA, más fácil) -----
# Regístrate gratis en https://apis.net.pe y copia tu token aquí.
# Con solo esto, el buscador de RUC jala datos reales de SUNAT.
APISNET_TOKEN=
# (opcional) cambiar la URL si usas otra versión/plan
APISNET_URL=https://api.apis.net.pe/v2/sunat/ruc

# --- Integración oficial SUNAT (OAuth2 con Clave SOL) ---------
# Estas credenciales se obtienen en SUNAT Operaciones en Línea (SOL)
# al registrar una aplicación / API de consulta de contribuyente.
SUNAT_CLIENT_ID=
SUNAT_CLIENT_SECRET=
# RUC de la empresa que consume la API (tu estudio/firma)
SUNAT_RUC=
# Usuario y clave SOL secundarios asociados a la app
SUNAT_SOL_USER=
SUNAT_SOL_PASS=

# Endpoints oficiales SUNAT (valores por defecto correctos para producción)
SUNAT_TOKEN_URL=https://api-seguridad.sunat.gob.pe/v1/clientessol
SUNAT_API_BASE=https://api.sunat.gob.pe/v1/contribuyente/contribuyentes

# Forzar modo simulado aunque existan credenciales (true/false)
SUNAT_FORCE_MOCK=false
