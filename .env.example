# ============================================================
#  Radar Tributar IA — Plantilla de variables de entorno
# ============================================================
# Este archivo es SOLO una PLANTILLA (no lleva valores reales).
# - En LOCAL: cópialo a `.env.local` y completa lo que necesites.
# - En PRODUCCIÓN: los valores REALES viven en Render → servicio
#   contaia → pestaña "Environment". NUNCA se suben al repositorio.
#
# Casi todo tiene valores por defecto correctos: para arrancar solo
# necesitas DECOLECTA_TOKEN (RUC real) y AUTH_SECRET. Sin credenciales
# SUNAT, la app corre en MODO SIMULADO para poder probar.
# ============================================================

# --- Núcleo (obligatorias en producción) ----------------------
# Secreto para firmar la cookie de sesión. Cadena larga y aleatoria.
AUTH_SECRET=
# Carpeta de datos persistentes. En Render con disco: /var/data
DATA_DIR=/var/data
# Navegadores headless simultáneos (cola). Regla: ~2 por cada 2 GB.
# Standard(2GB)=2 · Pro(4GB)=4 · Pro Max(16GB)=10
MAX_NAVEGADORES=10

# --- Usuario supremo (dueño de la plataforma) -----------------
# Se siembra/repara solo al arrancar. Cambia estos valores en prod.
SUPREMO_EMAIL=supremo@radartributaria.com
SUPREMO_PASSWORD=
SUPREMO_NOMBRE=Administrador supremo

# --- Consulta de RUC ------------------------------------------
# auto | decolecta | apisnet | oficial | mock
SUNAT_PROVIDER=decolecta
# Token de https://decolecta.com (panel del usuario). OBLIGATORIO para RUC real.
DECOLECTA_TOKEN=
DECOLECTA_URL=https://api.decolecta.com/v1/sunat/ruc/full
DECOLECTA_REPRESENTANTES_URL=https://api.decolecta.com/v1/sunat/ruc/representantes-legales
# Alternativa: apis.net.pe
APISNET_TOKEN=
APISNET_URL=https://api.apis.net.pe/v2/sunat/ruc
# Forzar datos simulados (útil para DEMOS masivas sin tocar SUNAT)
SUNAT_FORCE_MOCK=false

# --- Navegador remoto (opcional, Browserless) -----------------
# Si se define, buzón/F36/PDF corren remotos. OJO: SUNAT bloquea las IPs
# de Browserless (no sirve para buzón/F36). También puede guardarse desde
# el panel del supremo en vez de aquí.
BROWSER_WS_URL=

# --- Correo (recuperación de contraseña, opcional) ------------
RESEND_API_KEY=
EMAIL_FROM=Radar Tributar IA <no-reply@radartributaria.com>
# Base para los enlaces de los correos
APP_URL=https://radartributaria.com

# --- Integración oficial SUNAT (consulta contribuyente) -------
SUNAT_CLIENT_ID=
SUNAT_CLIENT_SECRET=
SUNAT_RUC=
SUNAT_SOL_USER=
SUNAT_SOL_PASS=
SUNAT_TOKEN_URL=https://api-seguridad.sunat.gob.pe/v1/clientessol
SUNAT_API_BASE=https://api.sunat.gob.pe/v1/contribuyente/contribuyentes

# --- SIRE: Compras y Ventas (RVIE / RCE) ----------------------
# La Clave SOL de cada cliente se ingresa por consulta y NO se guarda.
# El client_id/secret suele ir por cliente; aquí solo si usas uno común.
SUNAT_SIRE_CLIENT_ID=
SUNAT_SIRE_CLIENT_SECRET=
SIRE_SCOPE=https://api-sire.sunat.gob.pe
SIRE_API_BASE=https://api-sire.sunat.gob.pe/v1/contribuyente/migeigv/libros
SIRE_EXPORT_VENTAS_PATH=/rvierce/resumen/web/resumencomprobantes/{periodo}/{codTipoResumen}/{codTipoArchivo}/exporta?codLibro={codLibro}
SIRE_EXPORT_COMPRAS_PATH=/rvierce/resumen/web/resumencomprobantes/{periodo}/{codTipoResumen}/{codTipoArchivo}/exporta?codLibro={codLibro}
SIRE_ESTADO_PATH=/rvierce/gestionprocesosmasivos/web/masivo/consultaestadotickets?perIni={periodo}&perFin={periodo}&page=1&perPage=20&numTicket={ticket}
SIRE_DESCARGA_PATH=/rvierce/gestionprocesosmasivos/web/masivo/archivoreporte?nomArchivoReporte={nombre}&perTributario={periodo}&codLibro={codLibro}&codTipoArchivoReporte=00
SIRE_OMISOS_PATH=/rvierce/padron/web/omisos/{codLibro}/periodos
SIRE_COD_LIBRO_VENTAS=140000
SIRE_COD_LIBRO_COMPRAS=080000
SIRE_COD_TIPO_RESUMEN=2
SIRE_COD_TIPO_ARCHIVO=0
SIRE_FORCE_MOCK=false

# --- Buzón electrónico (endpoints internos del portal SOL) ----
# Tienen valores por defecto en el código; solo se sobreescriben para calibrar.
BUZON_LOGIN_URL=
BUZON_VISOR_URL=
BUZON_LIST_URL=
BUZON_BAJAR_URL=
BUZON_ARCHIVOS_URL=
BUZON_DETALLE_URL=
